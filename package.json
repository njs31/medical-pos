{
  "name": "pharmacy-pos",
  "version": "1.0.0",
  "description": "Cross-platform offline Pharmacy POS and Inventory Management desktop app",
  "main": "out/main/main.js",
  "author": "OpenAI Codex",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder --config electron-builder.config.js",
    "dist:win": "npm run build && electron-builder --config electron-builder.config.js --win --x64",
    "dist:win-arm": "npm run build && electron-builder --config electron-builder.config.js --win --arm64",
    "dist:mac": "npm run build && electron-builder --config electron-builder.config.js --mac"
  },
  "dependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "better-sqlite3": "^11.8.1",
    "clsx": "^2.1.1",
    "electron-log": "^5.4.1",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.20",
    "electron": "^35.0.1",
    "electron-builder": "^25.1.8",
    "electron-updater": "^6.8.3",
    "electron-vite": "^3.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "vite": "^6.2.2"
  }
}
